{% extends "base.html.twig" %}

{% block content %}
<div class="tag-index">
  <h1>{{ tag }}</h1>
  <p class="tag-meta">{{ total_files }} {{ total_files == 1 ? 'file' : 'files' }} tagged &ldquo;{{ tag }}&rdquo;</p>

  <div id="tag-files" class="file-list" data-per-page="{{ per_page }}">
    {% for file in tag_files %}
    <div class="file-item">
      <h2><a href="{{ file.url }}">{{ file.title }}</a></h2>
      {% if file.metadata.description %}
      <p class="file-description">{{ file.metadata.description }}</p>
      {% endif %}
    </div>
    {% endfor %}
  </div>

  <div id="pagination" class="pagination">
    {% if pagination_prev_url %}
    <a class="pagination-prev" href="{{ pagination_prev_url }}">Previous</a>
    {% endif %}
    <span class="pagination-status">Page {{ current_page }} of {{ total_pages }}</span>
    {% if pagination_next_url %}
    <a class="pagination-next" href="{{ pagination_next_url }}">Next</a>
    {% endif %}
  </div>
</div>

{% endblock %}
